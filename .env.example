# Database configuration — copy this file to .env and fill in the values.
# .env is gitignored: real credentials never reach the repository.

DB_USER=kuantorflow
DB_PASSWORD=your-password-here

# For local development with MySQL on your machine:
DB_HOST=localhost
DB_NAME=kuantorflow

# On PythonAnywhere, omit DB_HOST and DB_NAME (or delete those lines):
# they default to <DB_USER>.mysql.pythonanywhere-services.com
# and <DB_USER>$default.

# Optional: Flask session secret for flash messages (any long random string).
# SECRET_KEY=change-me-to-something-random
