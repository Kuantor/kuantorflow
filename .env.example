# Database configuration — copy this file to .env and fill in the values.
# .env is gitignored: real credentials never reach the repository.

DB_USER=kuantorflow
DB_PASSWORD=your-password-here

# For local development with MySQL on your machine:
DB_HOST=localhost
DB_NAME=kuantorflow

# On PythonAnywhere, omit DB_HOST and DB_NAME (or delete those lines):
# they default to <DB_USER>.mysql.pythonanywhere-services.com
# and <DB_USER>$default.

# Optional: Flask session secret for flash messages (any long random string).
# SECRET_KEY=change-me-to-something-random

# Keyword visitors must enter on the access screen before using the site.
ACCESS_KEYWORD=password

# Optional "Sign in with Google" for Mykola. Leave both blank to disable the
# feature (no sign-in button appears). To enable: create an OAuth 2.0 Client ID
# (type: Web application) in Google Cloud Console, add these redirect URIs —
#   https://<your-user>.pythonanywhere.com/auth/google/callback   (production)
#   http://localhost:5000/auth/google/callback                    (local dev)
# — then paste the client ID and secret below. Also set a real SECRET_KEY above
# (the session stores the signed-in identity).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
